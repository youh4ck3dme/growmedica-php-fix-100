<IfModule mod_authz_core.c>
    Require all granted
</IfModule>

<IfModule mod_access_compat.c>
    Order allow,deny
    Allow from all
</IfModule>

<FilesMatch "\.(php|html)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule mod_access_compat.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>