<IfModule mod_rewrite.c>
	RewriteEngine On

	#RewriteCond %{HTTP_HOST} ^growmedical.sk$ [OR]
	#RewriteCond %{HTTP_HOST} ^www.growmedical.sk$
	#RewriteRule (.*)$ https://www.growmedica.sk/$1 [R=301,L]

	#RewriteCond %{HTTPS} off [OR]
	#RewriteCond %{HTTP_HOST} !^www\. [NC]
	#RewriteCond %{HTTP_HOST} ^(.*)$  [NC]
	#RewriteRule (.*) https://www.growmedica/$1 [R=301,L]

	#RewriteCond %{HTTP_HOST} ^growmedical.sk$ [OR]
    #RewriteCond %{HTTP_HOST} ^www.growmedical.sk$ [NC]
    #RewriteRule ^(.*)$ https://www.growmedica.sk/$1 [R=301,L]

    RewriteCond %{HTTP_HOST} ^growmedical.sk$ [OR]
    RewriteCond %{HTTP_HOST} ^www.growmedical.sk$
    RewriteRule (.*)$ https://growmedica.sk/$1 [R=301,L]

    # Redirect from www. to non www.
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    RewriteRule ^sitemap\.xml$ sitemap/ [L]

	RewriteBase /
	# If   not   exists   file  or  directory

	RewriteCond %{SCRIPT_FILENAME} !(.*/content/.*)
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d

	RewriteRule ^(.*)$ index.php?param=$1 [L,QSA]
</IfModule>

# AuthUserFile /var/www/clients/client1/web743/web/.htpasswd
# AuthType Basic
# AuthName .htpasswd
# Require valid-user

<IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
</IfModule>


<FilesMatch "\.(?i:gif|jpe?g|png|webp|ico|svg|css|js|swf|woff)$">
	<IfModule mod_headers.c>
		Header set Cache-Control "max-age=172800, public, must-revalidate"
	</IfModule>
</FilesMatch>