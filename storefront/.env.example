# Shopify — server-side only (copy to .env.local; never commit real values)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token
SHOPIFY_REVALIDATION_SECRET=your-random-webhook-secret-min-16-chars
SHOPIFY_API_VERSION=2025-01

# Public site URL (safe for client bundles)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Legacy names (optional during migration — prefer SHOPIFY_* vars above)
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Mistral AI (server-only — never expose to client)
MISTRAL_API_KEY=
MISTRAL_API_KEY_BACKUP=
MISTRAL_MODEL=mistral-large-latest
# MISTRAL_MOCK_MODE=1  # only for Playwright integrity tests

# Optional — Upstash rate limiting for production AI endpoints
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NOOR demo — default theme + hide Classic/NOOR switcher on production demo
# When BOTH are set, localStorage theme preference is ignored (locked NOOR demo).
# NEXT_PUBLIC_DEFAULT_THEME=noor
# NEXT_PUBLIC_HIDE_THEME_SWITCHER=1
