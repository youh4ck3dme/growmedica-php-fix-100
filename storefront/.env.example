# Shopify — server-side only (copy to .env.local; never commit real values)
# Canonical: growmedica.myshopify.com (legacy tn43yx-0k.myshopify.com redirects here)
SHOPIFY_STORE_DOMAIN=growmedica.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token
SHOPIFY_REVALIDATION_SECRET=your-random-webhook-secret-min-16-chars
SHOPIFY_API_VERSION=2025-01

# Shopify Web Bot Auth — HTTP Message Signatures for verified crawlers (server-only)
# Generate in Shopify Admin → Settings → Apps and sales channels → Develop apps
SHOPIFY_WEB_BOT_AUTH_NAME=your-web-bot-auth-name
SHOPIFY_WEB_BOT_AUTH_DOMAIN=growmedica.myshopify.com
SHOPIFY_WEB_BOT_AUTH_SIGNATURE=sig1=:base64-signature-here:
SHOPIFY_WEB_BOT_AUTH_SIGNATURE_INPUT=sig1=("@authority" "signature-agent");keyid="...";nonce="...";tag="web-bot-auth";created=0;expires=0
SHOPIFY_WEB_BOT_AUTH_SIGNATURE_AGENT=https://shopify.com
SHOPIFY_WEB_BOT_AUTH_EXPIRES=YYYY-MM-DD

# Public site URL (safe for client bundles)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Externý admin dashboard (growmedica-nexus) — iframe src pre /dashboard
NEXT_PUBLIC_DASHBOARD_URL=https://growmedica-nexus.lovable.app/admin

# Legacy names (optional during migration — prefer SHOPIFY_* vars above)
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Mistral AI (server-only — never expose to client)
MISTRAL_API_KEY=
MISTRAL_API_KEY_BACKUP=
MISTRAL_MODEL=mistral-large-latest
# MISTRAL_MOCK_MODE=1  # only for Playwright integrity tests

# Optional — Shopify Admin API for local scripts (server-only, never in Vercel client)
# Scopes: write_products + read_products (bundles) | + read_inventory + write_inventory (inventory:fix)
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NOOR demo — default theme + hide Classic/NOOR switcher on production demo
# When BOTH are set, localStorage theme preference is ignored (locked NOOR demo).
# NEXT_PUBLIC_DEFAULT_THEME=noor
# NEXT_PUBLIC_HIDE_THEME_SWITCHER=1
